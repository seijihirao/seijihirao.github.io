rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBoardgameOwner() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/boardgameOwners/$(request.auth.token.email.lower()));
    }

    match /boardgames/{gameId} {
      allow read: if request.auth != null;

      // Borrow / return: any signed-in user, only those fields
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['borrowedBy', 'borrowedByName'])
        && (request.resource.data.borrowedBy == null
            || resource.data.get('lendable', true) != false);

      // Lendable (and owner transfer): only the current owner of the doc
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['owner', 'lendable'])
        && resource.data.get('owner', null) != null
        && resource.data.owner.id == request.auth.uid;

      allow create, delete: if isBoardgameOwner();
    }

    // Allowlist of emails permitted to add/delete boardgames.
    // Doc id = lowercase email. Existing owners can add or remove others.
    match /boardgameOwners/{email} {
      allow read: if request.auth != null;
      allow create, delete: if isBoardgameOwner();
    }

    match /health-docs/{fichaId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.auth.token.email in resource.data.sharedWith
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
